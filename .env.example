# Railguard environment (copy to .env.local and fill in)

# --- SignGate ---
APP_ENV=local
SIGNGATE_API_KEY=dev-local-signgate-key
HTTP_PORT=8080
POSTGRES_URL=postgres://railguard:railguard@localhost:5432/railguard?sslmode=disable
REDIS_ADDR=localhost:6379
OPA_POLICY_PATH=../policy/railguard.rego

# Receipt + session cosigning (Anvil account #1 — testnet/dev only)
RAILGUARD_SIGNER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
RECEIPT_SIGNER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
SIGNER_KEY_ID=railguard-key-v1

# --- Chain ---
CHAIN_ID=84532
RPC_URL=http://localhost:8545
ADAPTER_ADDRESS=
HOOK_ADDRESS=

# Watcher
WATCHER_ENABLED=true
WATCHER_START_BLOCK=0
WATCHER_RESCAN_BLOCKS=12
WATCHER_CONFIRMATION_DEPTH=0
USEROP_STALE_SECONDS=300

