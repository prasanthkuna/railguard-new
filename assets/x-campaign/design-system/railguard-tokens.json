{
  "$schema": "railguard-design-tokens-v1",
  "meta": {
    "name": "Railguard Sense",
    "version": "1.0.0",
    "theme": "dark",
    "description": "Semantic tokens for X infographics — Blade-style abstraction, Railguard colors"
  },
  "primitive": {
    "color.blue.500": "#3B82F6",
    "color.purple.500": "#A78BFA",
    "color.cyan.500": "#22D3EE",
    "color.green.500": "#22C55E",
    "color.red.500": "#EF4444",
    "color.amber.500": "#F59E0B",
    "color.zinc.950": "#0A0B0D",
    "color.zinc.900": "#14161A",
    "color.zinc.700": "#2A2D35",
    "color.zinc.100": "#F4F4F5",
    "color.zinc.400": "#A1A1AA"
  },
  "semantic": {
    "bg.primary": "{primitive.color.zinc.950}",
    "bg.elevated": "{primitive.color.zinc.900}",
    "border.default": "{primitive.color.zinc.700}",
    "text.primary": "{primitive.color.zinc.100}",
    "text.secondary": "{primitive.color.zinc.400}",
    "intent.neutral": "{primitive.color.zinc.400}",
    "intent.positive": "{primitive.color.green.500}",
    "intent.negative": "{primitive.color.red.500}",
    "intent.notice": "{primitive.color.amber.500}",
    "boundary.x402": "{primitive.color.blue.500}",
    "boundary.signgate": "{primitive.color.purple.500}",
    "boundary.cdp": "{primitive.color.cyan.500}",
    "truth.calm": "{semantic.intent.neutral}",
    "truth.resolved": "{semantic.intent.positive}",
    "truth.caution": "{semantic.intent.notice}",
    "truth.breach": "{semantic.intent.negative}"
  },
  "component": {
    "surface.card.default.bg": "{semantic.bg.elevated}",
    "surface.card.default.border": "{semantic.border.default}",
    "surface.card.exploit.border": "{semantic.truth.breach}",
    "surface.card.fix.border": "{semantic.truth.resolved}",
    "surface.insight.quote.border": "{semantic.boundary.x402}",
    "surface.state.unknown.border": "{semantic.truth.caution}",
    "surface.proof.pass.badge": "{semantic.truth.resolved}",
    "surface.cta.primary.bg": "{semantic.boundary.x402}",
    "surface.cta.primary.text": "{semantic.bg.primary}"
  },
  "typography": {
    "font.heading.family": "Inter",
    "font.heading.weight": "700",
    "font.body.family": "Inter",
    "font.body.weight": "400",
    "font.code.family": "JetBrains Mono",
    "font.code.weight": "400"
  },
  "spacing": {
    "page": "80px",
    "card": "32px",
    "stack.sm": "16px",
    "stack.md": "24px"
  },
  "radius": {
    "sm": "8px",
    "md": "12px"
  }
}
